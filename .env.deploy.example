# Copy this file to .env.deploy and fill in your settings.
# .env.deploy is gitignored.
#
# Authentication uses a dedicated SSH key — no password is stored here.
# Setup once:
#   1. ssh-keygen -t ed25519 -f ~/.ssh/id_villard -C "villard-deploy"
#   2. Add the public key (~/.ssh/id_villard.pub) to your Infomaniak SSH keys.
#   3. Set SFTP_SSH_KEY below to the private key path.

SFTP_HOST=villard.antoninpamart.fr
SFTP_USER=your-user
SFTP_PORT=22
# Path to the private SSH key used for the deploy (defaults to ~/.ssh/id_villard).
SFTP_SSH_KEY=~/.ssh/id_villard
# Absolute path on the remote server (e.g. /home/user/www or /var/www/html)
SFTP_REMOTE_DIR=/path/to/remote/dir
